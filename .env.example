# GW2 Progression — Environment Variables
# Copy to .env and fill in values

# Server
PORT=8000
ENV=development

# API release gates
# Production defaults should keep experimental AI Lab routes off unless explicitly enabled.
ENABLE_COMMERCE_ROUTES=true
ENABLE_INFRASTRUCTURE_ROUTES=true
ENABLE_AI_LAB_ROUTES=true
ENABLE_EXPERIMENTAL_ROUTES=true

# Rate Limiting (per IP)
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW=60

# GW2 API
GW2_API_BASE=https://api.guildwars2.com

# Logging
LOG_LEVEL=INFO

# LLM API Keys (optional — enables natural language advice)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Stripe (optional — enables payment/checkout)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Credential Server Secret (change in production!)
CREDENTIAL_SECRET=change-this-in-production

# CORS Origins (comma-separated, * for development)
CORS_ORIGINS=*

# Production (used by docker-compose.prod.yml)
# DOMAIN=gw2-progression.example.com
# SSL_EMAIL=admin@example.com
