FROM python:3.12-slim AS trainer

RUN groupadd -r app && useradd -r -g app -m -d /app app

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src/ ./src/

RUN pip install --no-cache-dir ".[training]" && \
    mkdir -p /app/models /app/data && \
    chown -R app:app /app

USER app

VOLUME ["/app/models", "/app/data"]

ENTRYPOINT ["python", "-m", "gw2_progression.trainer.worker"]
CMD ["--checkpoint-dir", "/app/models", "--min-batch", "20"]
